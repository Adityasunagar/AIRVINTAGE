# ─────────────────────────────────────────────
#  AirVintage — .gitignore
# ─────────────────────────────────────────────

# ══════════════════════════════════════════════
#  PYTHON / BACKEND
# ══════════════════════════════════════════════

# Byte-compiled / optimised
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
*.pytest_cache

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# ══════════════════════════════════════════════
#  ML MODEL
# ══════════════════════════════════════════════

# Trained model binaries (usually too large for git; use Git LFS if needed)
backend/app/model/*.pkl
backend/app/model/*.joblib
backend/app/model/*.h5
backend/app/model/*.pt
backend/app/model/*.pth

# Training artefacts / logs
backend/app/model/logs/
backend/app/model/checkpoints/

# ══════════════════════════════════════════════
#  ENVIRONMENT & SECRETS
# ══════════════════════════════════════════════

.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# ══════════════════════════════════════════════
#  REACT / NODE (FRONTEND)
# ══════════════════════════════════════════════

# Dependencies
frontend/node_modules/
node_modules/
/.pnp
/.pnp.js

# Production build
frontend/build/
frontend/dist/

# Create React App cache
frontend/.eslintcache

# Testing
frontend/coverage/

# Misc CRA
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# npm / yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ══════════════════════════════════════════════
#  OPERATING SYSTEM
# ══════════════════════════════════════════════

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# ══════════════════════════════════════════════
#  EDITORS & IDEs
# ══════════════════════════════════════════════

# VS Code (keep shared settings, ignore personal)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# JetBrains (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws

# Vim / Emacs
*.swp
*.swo
*.bak
*~

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/

# ══════════════════════════════════════════════
#  MISC
# ══════════════════════════════════════════════

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp

# API response cache (generated data)
backend/app/weather.json
