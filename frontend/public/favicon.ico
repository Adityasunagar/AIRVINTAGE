<svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <!-- Milder Neon Glow Filter -->
    <filter id="neon" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="1" result="blur1" />
      <feGaussianBlur in="SourceGraphic" stdDeviation="2.5" result="blur2" />
      <feMerge>
        <feMergeNode in="blur2" />
        <feMergeNode in="blur1" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
  </defs>
  
  <g filter="url(#neon)">
    <!-- Base diffuse blue glow layer (toned down) -->
    <path 
      d="M12 28L20 8L28 28 M10 24Q20 18 30 24" 
      stroke="#0ea5e9" 
      stroke-width="3.5" 
      stroke-opacity="0.8"
      stroke-linecap="round" 
      stroke-linejoin="round"
    />
    <!-- Intense cyan middle layer -->
    <path 
      d="M12 28L20 8L28 28 M10 24Q20 18 30 24"
      stroke="#38bdf8" 
      stroke-width="2.5" 
      stroke-linecap="round" 
      stroke-linejoin="round"
    />
    <!-- Super-bright white/cyan tube core -->
    <path 
      d="M12 28L20 8L28 28 M10 24Q20 18 30 24"
      stroke="#ffffff" 
      stroke-width="1.2" 
      stroke-linecap="round" 
      stroke-linejoin="round"
    />
  </g>
</svg>